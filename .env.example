# Taxi4U Booking API Configuration
# Get your API credentials from Taxi4U
TAXI4U_USER_ID=your_user_id_here
TAXI4U_PASSWORD=your_password_here
TAXI4U_CENTRAL_CODE=VOSS

# Calculator URL
# Update this with your deployed calculator URL
# Default: https://voss-taxi-kalkulator.vercel.app
NEXT_PUBLIC_CALCULATOR_URL=https://voss-taxi-kalkulator.vercel.app

# Google Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Booking Configuration (Optional)
# NEXT_PUBLIC_BOOKING_PHONE=+4756511340
# NEXT_PUBLIC_BOOKING_EMAIL=post@vosstaxi.no

# SMS Configuration (Twilio - Optional)
# Get your credentials from https://www.twilio.com/console
# If not configured, booking will work but no SMS will be sent
# TWILIO_ACCOUNT_SID=your_account_sid_here
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890
