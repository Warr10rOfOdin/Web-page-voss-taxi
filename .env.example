# Taxi4U Booking API Configuration
# Get your API credentials from Taxi4U
TAXI4U_USER_ID=your_user_id_here
TAXI4U_PASSWORD=your_password_here
TAXI4U_CENTRAL_CODE=VOSS
# Default taxi account number for website bookings (kontonr)
# This is required by Taxi4U API - use your default account number
TAXI4U_DEFAULT_ACCOUNT_NO=0

# Calculator URL
# Update this with your deployed calculator URL
# Default: https://voss-taxi-kalkulator.vercel.app
NEXT_PUBLIC_CALCULATOR_URL=https://voss-taxi-kalkulator.vercel.app

# Google Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Booking Configuration (Optional)
# NEXT_PUBLIC_BOOKING_PHONE=+4756511340
# NEXT_PUBLIC_BOOKING_EMAIL=post@vosstaxi.no

# Email Configuration (SMTP - Optional)
# Configure SMTP settings for sending booking confirmations and feedback
# If not configured, booking will work but no email confirmation will be sent
# For one.com email hosting, use these typical settings:
# SMTP_HOST=send.one.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@vosstaxi.no
# SMTP_PASS=your_email_password_here
# SMTP_FROM=Voss Taxi <noreply@vosstaxi.no>
# FEEDBACK_EMAIL=post@vosstaxi.no
