# ====================================
# Voss Taxi Environment Configuration
# ====================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ====================================
# REQUIRED: Taxi4U API Configuration
# ====================================
# These are REQUIRED for the booking system to work
# Contact Taxi4U to get your API credentials
TAXI4U_USER_ID=your_user_id_here
TAXI4U_PASSWORD=your_password_here
TAXI4U_CENTRAL_CODE=VS
TAXI4U_DEFAULT_ACCOUNT_NO=0

# ====================================
# OPTIONAL: SMTP Email Configuration
# ====================================
# Configure these to enable email receipts and confirmations
# If not configured, receipts can still be downloaded as PDFs

# One.com SMTP settings (SSL/TLS on port 465):
SMTP_HOST=send.one.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@vosstaxi.no
SMTP_PASS=your_email_password_here
SMTP_FROM=Voss Taxi <noreply@vosstaxi.no>

# Feedback email recipient
FEEDBACK_EMAIL=post@vosstaxi.no

# ====================================
# OPTIONAL: Other Configuration
# ====================================

# Calculator URL (default: https://voss-taxi-kalkulator.vercel.app)
NEXT_PUBLIC_CALCULATOR_URL=https://voss-taxi-kalkulator.vercel.app

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Booking contact info (optional)
NEXT_PUBLIC_BOOKING_PHONE=+4756511340
NEXT_PUBLIC_BOOKING_EMAIL=post@vosstaxi.no
